# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion Integration (required for Notion MCP)
NOTION_API_KEY=your_notion_integration_token_here

# Notion Database IDs (required)
# Create these databases in Notion and paste their IDs here
NOTION_JOBS_DB_ID=your_jobs_database_id_here
NOTION_RESUMES_DB_ID=your_resumes_database_id_here
NOTION_OUTPUTS_DB_ID=your_outputs_database_id_here

# Optional: Web search for company context
GEMINI_API_KEY=your_gemini_api_key_here
BRAVE_API_KEY=your_brave_search_api_key_here
